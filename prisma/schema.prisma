generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  ADMIN
  MANAGER
  HR
  USER
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  RETURNED
}

enum WorkflowInstanceStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum JobType {
  IMPORT
  EXPORT
  EMAIL
  NOTIFICATION
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  forms               Form[]
  submissions         Submission[]
  workflowDefinitions WorkflowDefinition[]
  jobRecords          JobRecord[]
  fileRecords         FileRecord[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  apiKeys             ApiKey[]
  settings            Setting[]
  workflowInstances   WorkflowInstance[]
  workflowHistories   WorkflowHistory[]
  refreshTokens       RefreshToken[]
  delegations         Delegation[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  keycloakId   String?   @map("keycloak_id")
  email        String    
  username     String    
  passwordHash String?   @map("password_hash")
  role         Role      @default(USER)
  firstName    String?
  lastName     String?
  picture      String?
  isActive     Boolean   @default(true)

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant                 Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens          RefreshToken[]
  forms                  Form[]
  submissions            Submission[]
  workflowDefinitions    WorkflowDefinition[]
  notifications          Notification[]
  jobRecords             JobRecord[]
  fileRecords            FileRecord[]
  delegatedHistories     WorkflowHistory[]    @relation("DelegatedHistory")
  delegationsFrom        Delegation[]         @relation("DelegatedFrom")
  delegationsTo          Delegation[]         @relation("DelegatedTo")

  @@map("users")
  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@unique([tenantId, keycloakId])
  @@index([tenantId])
  @@index([email])
  @@index([role])
}

model RefreshToken {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  token       String   @unique
  userId      String   @map("user_id")
  tokenFamily String   @default(uuid()) @map("token_family")
  isRevoked   Boolean  @default(false) @map("is_revoked")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([tenantId])
  @@index([userId])
  @@index([tokenFamily])
}

model Form {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  schema      Json      // Form fields schema
  settings    Json      // Form configurations
  isActive    Boolean   @default(true) @map("is_active")

  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                 User                 @relation(fields: [createdBy], references: [id])
  submissions          Submission[]
  workflowDefinitions  WorkflowDefinition[]

  @@map("forms")
  @@index([tenantId])
  @@index([createdBy])
}

model Submission {
  id                 String           @id @default(uuid())
  tenantId           String           @map("tenant_id")
  formId             String           @map("form_id")
  data               Json             // Actual submitted data
  status             SubmissionStatus @default(DRAFT)
  submittedBy        String           @map("submitted_by")
  parentSubmissionId String?          @map("parent_submission_id")
  revisionNumber     Int              @default(1) @map("revision_number")

  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form             Form               @relation(fields: [formId], references: [id], onDelete: Restrict)
  user             User               @relation(fields: [submittedBy], references: [id])
  workflows        WorkflowInstance[]
  parentSubmission Submission?        @relation("SubmissionRevisions", fields: [parentSubmissionId], references: [id])
  childSubmissions Submission[]       @relation("SubmissionRevisions")

  @@map("submissions")
  @@index([tenantId])
  @@index([formId])
  @@index([submittedBy])
  @@index([parentSubmissionId])
}

model WorkflowDefinition {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  config      Json     // Steps and transitions
  formId      String?  @map("form_id")
  createdBy   String   @map("created_by")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form        Form?              @relation(fields: [formId], references: [id], onDelete: SetNull)
  user        User               @relation(fields: [createdBy], references: [id])
  instances   WorkflowInstance[]

  @@map("workflow_definitions")
  @@index([tenantId])
  @@index([formId])
}

model WorkflowInstance {
  id           String                 @id @default(uuid())
  tenantId     String                 @map("tenant_id")
  definitionId String                 @map("definition_id")
  submissionId String                 @map("submission_id")
  currentStep  String                 @map("current_step")
  status       WorkflowInstanceStatus @default(ACTIVE)

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id])
  submission   Submission         @relation(fields: [submissionId], references: [id])
  histories    WorkflowHistory[]

  @@map("workflow_instances")
  @@index([tenantId])
  @@index([definitionId])
  @@index([submissionId])
}

model WorkflowHistory {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  instanceId String   @map("instance_id")
  fromStep   String?  @map("from_step")
  toStep     String   @map("to_step")
  action     String   // E.g., SUBMITTED, APPROVED, REJECTED
  actorId    String   @map("actor_id")
  comment    String?
  delegatedForId String?  @map("delegated_for_id")

  createdAt  DateTime @default(now()) @map("created_at")

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  delegatedFor User?          @relation("DelegatedHistory", fields: [delegatedForId], references: [id])

  @@map("workflow_histories")
  @@index([tenantId])
  @@index([instanceId])
  @@index([delegatedForId])
}

model FileRecord {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  originalName String   @map("original_name")
  storedName   String   @map("stored_name")
  storedPath   String   @map("stored_path")
  mimeType     String   @map("mime_type")
  size         Int
  uploadedBy   String   @map("uploaded_by")

  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [uploadedBy], references: [id])

  @@map("file_records")
  @@index([tenantId])
}

model JobRecord {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  type      JobType
  status    JobStatus @default(PENDING)
  progress  Int       @default(0)
  result    Json?
  error     String?
  createdBy String    @map("created_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [createdBy], references: [id])

  @@map("job_records")
  @@index([tenantId])
  @@index([status])
  @@index([type])
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  title     String
  content   String
  type      String   // e.g. "INFO", "SUCCESS", "WARNING"
  read      Boolean  @default(false)
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([tenantId])
  @@index([userId, read])
}

model Setting {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  key       String   
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("settings")
  @@unique([tenantId, key])
  @@index([tenantId])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  actorId     String   @map("actor_id") // userId or apiKeyId
  action      String   // CREATE, UPDATE, DELETE, EXPORT, APPROVE, REJECT
  targetModel String   @map("target_model") // e.g. "Submission", "User"
  targetId    String   @map("target_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
  @@index([tenantId])
  @@index([actorId])
  @@index([targetModel, targetId])
}

model ApiKey {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  keyHash   String    @map("key_hash")
  scopes    Json?     // Array of allowed permissions/roles
  expiresAt DateTime? @map("expires_at")
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_keys")
  @@index([tenantId])
}

model Delegation {
  id                    String   @id @default(uuid())
  tenantId              String   @map("tenant_id")
  fromUserId            String   @map("from_user_id")
  toUserId              String   @map("to_user_id")
  startDate             DateTime @map("start_date")
  endDate               DateTime @map("end_date")
  isActive              Boolean  @default(true) @map("is_active")
  formIds               String[] @default([]) @map("form_ids")
  workflowDefinitionIds String[] @default([]) @map("workflow_definition_ids")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromUser   User     @relation("DelegatedFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("DelegatedTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@map("delegations")
  @@index([tenantId])
  @@index([fromUserId])
  @@index([toUserId])
}
