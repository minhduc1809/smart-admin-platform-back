# Application
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:8000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/smart_admin_db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Auth
JWT_ACCESS_SECRET=your_super_secret_access_key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key
JWT_REFRESH_EXPIRATION=7d

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=smart-admin
KEYCLOAK_CLIENT_ID=smart-admin-backend
KEYCLOAK_CLIENT_SECRET=smart-admin-backend-secret

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DEST=./uploads

# Cloudinary (for avatar/image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

